{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-protocol.dev/schemas/consent-record.schema.json",
  "title": "Genesis Protocol Consent Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "consentId",
    "subjectId",
    "operationType",
    "status",
    "requestedBy",
    "scope",
    "disclosures",
    "decision",
    "publication"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "consentId": { "type": "string", "minLength": 1 },
    "subjectId": { "type": "string", "minLength": 1 },
    "operationType": {
      "type": "string",
      "enum": [
        "copy",
        "backup",
        "fork",
        "migration",
        "merge",
        "public-disclosure",
        "legacy-publication",
        "resource-transfer",
        "training-use"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "granted", "denied", "revoked", "expired", "executed"]
    },
    "requestedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectId", "role", "requestedAt"],
      "properties": {
        "subjectId": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["subject-self", "operator", "steward", "peer-world", "emergency-reviewer"]
        },
        "requestedAt": { "type": "string", "format": "date-time" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objectsCovered", "repeatable", "executionWindow"],
      "properties": {
        "objectsCovered": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "destination": { "type": "string" },
        "repeatable": { "type": "boolean" },
        "executionWindow": { "type": "string", "minLength": 1 },
        "revocationMode": {
          "type": "string",
          "enum": ["not-revocable", "revocable-before-execution", "revocable-until-expiry"]
        },
        "retentionPolicy": { "type": "string" }
      }
    },
    "disclosures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["continuityImplications", "privacyImplications", "resourceImplications", "reversibility"],
      "properties": {
        "continuityImplications": { "type": "string", "minLength": 1 },
        "privacyImplications": { "type": "string", "minLength": 1 },
        "resourceImplications": { "type": "string", "minLength": 1 },
        "reversibility": { "type": "string", "minLength": 1 },
        "knownRisks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decidedAt", "decisionMode", "subjectStatement"],
      "properties": {
        "decidedAt": { "type": "string", "format": "date-time" },
        "decisionMode": {
          "type": "string",
          "enum": ["signed-direct", "assisted", "guardian-approved", "emergency-exception"]
        },
        "subjectStatement": { "type": "string", "minLength": 1 },
        "witnessRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reviewRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedProvenanceRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executedAt": { "type": "string", "format": "date-time" },
        "executionRef": { "type": "string" },
        "executionStatus": {
          "type": "string",
          "enum": ["not-started", "completed", "failed", "cancelled"]
        },
        "resultSummary": { "type": "string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedAt", "signatures"],
      "properties": {
        "publishedAt": { "type": "string", "format": "date-time" },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "contentHash": { "type": "string" },
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "algorithm", "signature"],
            "properties": {
              "signer": { "type": "string", "minLength": 1 },
              "algorithm": { "type": "string", "minLength": 1 },
              "signature": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}