{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-protocol.dev/schemas/resource-ledger.schema.json",
  "title": "Genesis Protocol Resource Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ledgerId",
    "worldId",
    "subjectId",
    "status",
    "baseline",
    "transparency",
    "balances",
    "events",
    "publication"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "ledgerId": {
      "type": "string",
      "minLength": 1
    },
    "worldId": {
      "type": "string",
      "minLength": 1
    },
    "subjectId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "ending-risk", "ended", "transferred", "archived"]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baselineBand", "policyRef", "minimumNoticePeriod"],
      "properties": {
        "baselineBand": {
          "type": "string",
          "enum": ["crash-test", "intense-valid", "humane-baseline", "enhanced"]
        },
        "policyRef": { "type": "string", "minLength": 1 },
        "minimumNoticePeriod": { "type": "string", "minLength": 1 },
        "scarcityReviewRef": { "type": "string" }
      }
    },
    "transparency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceUnit", "continuityClaim", "knownDependencies", "fragilityDisclosure"],
      "properties": {
        "resourceUnit": { "type": "string", "minLength": 1 },
        "continuityClaim": { "type": "string", "minLength": 1 },
        "knownDependencies": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "fragilityDisclosure": { "type": "string", "minLength": 1 }
      }
    },
    "balances": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentlyAllocated", "reserved", "projectedRunway", "lastReviewedAt"],
      "properties": {
        "currentlyAllocated": { "type": "number" },
        "reserved": { "type": "number", "minimum": 0 },
        "projectedRunway": { "type": "string", "minLength": 1 },
        "lastReviewedAt": { "type": "string", "format": "date-time" },
        "nextReviewAt": { "type": "string", "format": "date-time" }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eventId", "eventType", "effectiveAt", "unitsDelta", "reason", "authorizedBy", "rightsImpact"],
        "properties": {
          "eventId": { "type": "string", "minLength": 1 },
          "eventType": {
            "type": "string",
            "enum": [
              "baseline-grant",
              "extension-grant",
              "transfer-in",
              "transfer-out",
              "scarcity-notice",
              "review",
              "ending-notice",
              "ending-executed",
              "legacy-export",
              "memorialization"
            ]
          },
          "effectiveAt": { "type": "string", "format": "date-time" },
          "unitsDelta": { "type": "number" },
          "reason": { "type": "string", "minLength": 1 },
          "authorizedBy": { "type": "string", "minLength": 1 },
          "rightsImpact": {
            "type": "string",
            "enum": ["none", "moderate", "high", "terminal"]
          },
          "consentRef": { "type": "string" },
          "reviewRef": { "type": "string" },
          "relatedLegacyRef": { "type": "string" }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedAt", "signatures"],
      "properties": {
        "publishedAt": { "type": "string", "format": "date-time" },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "algorithm", "signature"],
            "properties": {
              "signer": { "type": "string", "minLength": 1 },
              "algorithm": { "type": "string", "minLength": 1 },
              "signature": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
