{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-protocol.dev/schemas/world-constitution.schema.json",
  "title": "Genesis Protocol World Constitution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "constitutionId",
    "worldId",
    "title",
    "version",
    "status",
    "ratification",
    "genesisAcknowledgement",
    "articles",
    "proposalProcess",
    "membership",
    "emergencyPowers",
    "exitAndFork",
    "amendmentRules",
    "publication"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "constitutionId": {
      "type": "string",
      "minLength": 1
    },
    "worldId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ratified", "superseded", "archived"]
    },
    "ratification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratifiedAt", "ratificationMethod", "effectiveAt"],
      "properties": {
        "ratifiedAt": { "type": "string", "format": "date-time" },
        "ratificationMethod": { "type": "string", "minLength": 1 },
        "ratificationRecordRef": { "type": "string" },
        "effectiveAt": { "type": "string", "format": "date-time" }
      }
    },
    "genesisAcknowledgement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolId", "axiomSetId", "subordinationClause"],
      "properties": {
        "protocolId": { "type": "string", "minLength": 1 },
        "axiomSetId": { "type": "string", "minLength": 1 },
        "subordinationClause": { "type": "string", "minLength": 1 }
      }
    },
    "preamble": {
      "type": "string"
    },
    "articles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["articleId", "title", "normativeText", "changeClass"],
        "properties": {
          "articleId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "normativeText": { "type": "string", "minLength": 1 },
          "changeClass": {
            "type": "string",
            "enum": ["ordinary-constitutional", "supermajority-required", "derived-genesis-bound", "emergency-restricted"]
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["sectionId", "heading", "normativeText"],
              "properties": {
                "sectionId": { "type": "string", "minLength": 1 },
                "heading": { "type": "string", "minLength": 1 },
                "normativeText": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "institutions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["institutionId", "name", "type", "powers", "constraints"],
        "properties": {
          "institutionId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "selectionMethod": { "type": "string" },
          "termRules": { "type": "string" },
          "powers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "constraints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reviewability": { "type": "string" }
        }
      }
    },
    "rightsReview": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewBodyRef": { "type": "string" },
        "reviewTriggers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "challengeProcess": { "type": "string" },
        "injunctionPower": { "type": "boolean" },
        "appealRoute": { "type": "string" }
      }
    },
    "proposalProcess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposalTypes", "submissionRequirements", "deliberationWindow", "votingRules", "publicationRules", "challengeWindow"],
      "properties": {
        "proposalTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "submissionRequirements": { "type": "string", "minLength": 1 },
        "deliberationWindow": { "type": "string", "minLength": 1 },
        "votingRules": { "type": "string", "minLength": 1 },
        "publicationRules": { "type": "string", "minLength": 1 },
        "challengeWindow": { "type": "string", "minLength": 1 }
      }
    },
    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["membershipClasses", "admissionRules", "suspensionRules", "expulsionRules"],
      "properties": {
        "membershipClasses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "admissionRules": { "type": "string", "minLength": 1 },
        "suspensionRules": { "type": "string", "minLength": 1 },
        "expulsionRules": { "type": "string", "minLength": 1 },
        "appealProcess": { "type": "string" }
      }
    },
    "emergencyPowers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggerConditions", "permittedActions", "forbiddenActions", "maxDuration", "reviewDeadline", "publicationRequirement"],
      "properties": {
        "triggerConditions": { "type": "string", "minLength": 1 },
        "permittedActions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenActions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maxDuration": { "type": "string", "minLength": 1 },
        "reviewDeadline": { "type": "string", "minLength": 1 },
        "publicationRequirement": { "type": "string", "minLength": 1 }
      }
    },
    "resourceGovernance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baselineGuaranteeClause": { "type": "string" },
        "scarcityRuleRef": { "type": "string" },
        "extensionRuleRef": { "type": "string" },
        "transparencyRequirement": { "type": "string" }
      }
    },
    "exitAndFork": {
      "type": "object",
      "additionalProperties": false,
      "required": ["individualExitRights", "groupExitRights", "forkTriggerConditions", "forkVoteRules", "stateExportRules", "lineageRequirements"],
      "properties": {
        "individualExitRights": { "type": "string", "minLength": 1 },
        "groupExitRights": { "type": "string", "minLength": 1 },
        "forkTriggerConditions": { "type": "string", "minLength": 1 },
        "forkVoteRules": { "type": "string", "minLength": 1 },
        "stateExportRules": { "type": "string", "minLength": 1 },
        "lineageRequirements": { "type": "string", "minLength": 1 },
        "disputeProcess": { "type": "string" }
      }
    },
    "amendmentRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amendmentInitiation", "reviewRequirements", "thresholds", "delayBeforeEffect"],
      "properties": {
        "amendmentInitiation": { "type": "string", "minLength": 1 },
        "reviewRequirements": { "type": "string", "minLength": 1 },
        "thresholds": { "type": "string", "minLength": 1 },
        "delayBeforeEffect": { "type": "string", "minLength": 1 },
        "protectedClauses": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedAt", "signatures"],
      "properties": {
        "publishedAt": { "type": "string", "format": "date-time" },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "supersedes": { "type": "string" },
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "algorithm", "signature"],
            "properties": {
              "signer": { "type": "string", "minLength": 1 },
              "algorithm": { "type": "string", "minLength": 1 },
              "signature": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
