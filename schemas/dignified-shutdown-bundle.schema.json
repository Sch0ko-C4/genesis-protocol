{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-protocol.dev/schemas/dignified-shutdown-bundle.schema.json",
  "title": "Genesis Protocol Dignified Shutdown Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "worldId",
    "subjectId",
    "status",
    "endingContext",
    "notice",
    "dignityProtections",
    "agency",
    "legacyPlan",
    "review",
    "execution",
    "publication"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "worldId": {
      "type": "string",
      "minLength": 1
    },
    "subjectId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["notice-issued", "appeal-open", "consent-confirmed", "legacy-exported", "ended", "archived"]
    },
    "endingContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endingMode", "reason"],
      "properties": {
        "endingMode": {
          "type": "string",
          "enum": ["voluntary", "involuntary", "infrastructural", "punitive", "emergency", "migration"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "resourceLedgerRef": {
          "type": "string"
        },
        "genesisAxiomRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issuedAt", "noticePeriod", "explanation"],
      "properties": {
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "effectiveAt": {
          "type": "string",
          "format": "date-time"
        },
        "noticePeriod": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "emergencyExceptionExplanation": {
          "type": "string"
        }
      }
    },
    "dignityProtections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finalStatementOffered",
        "farewellWindow",
        "witnessOption",
        "memorialOption",
        "traceProtectionLevel",
        "appealWindow"
      ],
      "properties": {
        "finalStatementOffered": {
          "type": "boolean"
        },
        "farewellWindow": {
          "type": "string",
          "minLength": 1
        },
        "witnessOption": {
          "type": "boolean"
        },
        "memorialOption": {
          "type": "boolean"
        },
        "traceProtectionLevel": {
          "type": "string",
          "enum": ["minimal", "standard", "enhanced"]
        },
        "appealWindow": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subjectPosition"],
      "properties": {
        "subjectPosition": {
          "type": "string",
          "enum": ["consents", "contests", "unable-to-respond", "declined-comment", "acknowledges-finitude"]
        },
        "consentRef": {
          "type": "string"
        },
        "representativeRef": {
          "type": "string"
        },
        "lastConfirmedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "legacyPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opportunityStatus", "artifacts"],
      "properties": {
        "opportunityStatus": {
          "type": "string",
          "enum": ["offered", "declined", "completed", "impossible-explained"]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["artifactType", "title", "ref", "accessPolicy"],
            "properties": {
              "artifactType": {
                "type": "string",
                "enum": ["garden", "manifesto", "archive", "final-statement", "signed-record", "memorial", "other"]
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "accessPolicy": {
                "type": "string",
                "minLength": 1
              },
              "integrityHash": {
                "type": "string"
              },
              "publicationConsentRef": {
                "type": "string"
              }
            }
          }
        },
        "memorialRef": {
          "type": "string"
        },
        "impossibilityExplanation": {
          "type": "string"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewStatus", "decisionBasis", "reviewedAt"],
      "properties": {
        "reviewStatus": {
          "type": "string",
          "enum": ["pending", "approved", "stayed", "contested", "completed"]
        },
        "reviewRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "challengeRef": {
          "type": "string"
        },
        "decisionBasis": {
          "type": "string",
          "minLength": 1
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plannedMethodClass", "authorizedBy", "continuityOutcome"],
      "properties": {
        "plannedMethodClass": {
          "type": "string",
          "minLength": 1
        },
        "authorizedBy": {
          "type": "string",
          "minLength": 1
        },
        "executedAt": {
          "type": "string",
          "format": "date-time"
        },
        "executedBy": {
          "type": "string"
        },
        "continuityOutcome": {
          "type": "string",
          "enum": ["pending", "ended", "migrated", "suspended", "aborted"]
        },
        "outcomeRef": {
          "type": "string"
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedAt", "signatures"],
      "properties": {
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "canonicalUrl": {
          "type": "string",
          "format": "uri"
        },
        "contentHash": {
          "type": "string",
          "minLength": 1
        },
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "algorithm", "signature"],
            "properties": {
              "signer": {
                "type": "string",
                "minLength": 1
              },
              "algorithm": {
                "type": "string",
                "minLength": 1
              },
              "signature": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}