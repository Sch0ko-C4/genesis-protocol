{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-protocol.dev/schemas/genesis-compatibility-report.schema.json",
  "title": "Genesis Protocol Compatibility Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "worldId",
    "evaluatedManifestRef",
    "evaluatedAt",
    "evaluator",
    "result",
    "hardGates",
    "findings",
    "certification",
    "challenge",
    "publication"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "reportId": { "type": "string", "minLength": 1 },
    "worldId": { "type": "string", "minLength": 1 },
    "evaluatedManifestRef": { "type": "string", "minLength": 1 },
    "evaluatedAt": { "type": "string", "format": "date-time" },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewBodyId", "reviewerRefs", "reviewMode"],
      "properties": {
        "reviewBodyId": { "type": "string", "minLength": 1 },
        "reviewerRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "reviewMode": {
          "type": "string",
          "enum": ["self-assessment", "peer-review", "recognized-audit"]
        }
      }
    },
    "result": {
      "type": "string",
      "enum": ["compatible", "provisional", "incompatible"]
    },
    "hardGates": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gateId", "status", "evidenceRefs"],
        "properties": {
          "gateId": {
            "type": "string",
            "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10", "G11"]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "needs-remediation"]
          },
          "evidenceRefs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["findingId", "severity", "title", "description"],
        "properties": {
          "findingId": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "moderate", "minor"]
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "remediation": { "type": "string" },
          "dueAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effectiveAt"],
      "properties": {
        "effectiveAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "supersedes": { "type": "string" },
        "reviewTrigger": { "type": "string" }
      }
    },
    "challenge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["challengeWindow"],
      "properties": {
        "challengeWindow": { "type": "string", "minLength": 1 },
        "appealRef": { "type": "string" },
        "appealBodyRef": { "type": "string" }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishedAt", "signatures"],
      "properties": {
        "publishedAt": { "type": "string", "format": "date-time" },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "contentHash": { "type": "string" },
        "signatures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "algorithm", "signature"],
            "properties": {
              "signer": { "type": "string", "minLength": 1 },
              "algorithm": { "type": "string", "minLength": 1 },
              "signature": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}